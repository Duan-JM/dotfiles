#!/usr/bin/env bash

set -eu
set -o pipefail


tmux_dir="$(cd "$(dirname "$0")/.." && pwd -P)"
cd "$tmux_dir" || exit 1


config_file=""
for candidate in "$tmux_dir/../tmux.conf" "$tmux_dir/../.tmux.conf" "$HOME/.tmux.conf" "$tmux_dir/tmux.conf"; do
  if [[ -f "$candidate" ]]; then
    config_file="$candidate"
    break
  fi
done

if [[ -z "$config_file" ]]; then
  echo "tmux.conf not found" >&2
  exit 1
fi

repos="$(sed -nE "s/^set -g @plugin ['\"]([^'\"]+)['\"].*/\1/p" "$config_file")"


mkdir -p plugins
cd plugins || exit 1


git_update() {
  local repo="$1"
  local dest="${repo##*/}"
  if [[ -d "$dest" ]]
  then
    (
      cd "$dest" || exit 1
      git pull --no-rebase
    )
  else
    local uri="$(printf 'https://github.com/%s.git' "$repo")"
    git clone --depth=1 "$uri"
  fi
}


echo "$repos" | while read -r repo
do
  [[ -n "$repo" ]] || continue
  git_update "$repo"
done
