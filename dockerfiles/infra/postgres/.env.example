DB_NAME=app
DB_USER=app
DB_PASSWORD=change-me-use-a-long-random-password
DB_HOST=127.0.0.1
DB_PORT=5432
TZ=Asia/Shanghai

# Optional replication user for streaming replication and physical base backups.
REPLICATION_USER=replicator
REPLICATION_PASSWORD=change-me-use-a-different-long-random-password

# Optional operational tuning.
CONTAINER_NAME=infra_postgres
POSTGRES_SHM_SIZE=256mb
BACKUP_RETENTION_DAYS=14
BASEBACKUP_RETENTION_DAYS=7
LOG_MAX_SIZE=100m
LOG_MAX_FILE=10

# Container-managed automatic backups. Cron format uses the backup container timezone.
LOGICAL_BACKUP_ENABLED=true
LOGICAL_BACKUP_CRON='15 2 * * *'
LOGICAL_BACKUP_ON_START=false
BASEBACKUP_ENABLED=true
BASEBACKUP_CRON='15 3 * * 0'
