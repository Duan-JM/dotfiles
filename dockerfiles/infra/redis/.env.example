REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change-me-use-a-long-random-password
TZ=Asia/Shanghai

CONTAINER_NAME=infra_redis
LOG_MAX_SIZE=100m
LOG_MAX_FILE=10

# Container-managed automatic RDB backups. Cron format uses the backup container timezone.
REDIS_BACKUP_ENABLED=true
REDIS_BACKUP_CRON='30 2 * * *'
REDIS_BACKUP_ON_START=false
REDIS_BACKUP_RETENTION_DAYS=14

